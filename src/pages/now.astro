---
import Layout from '../layouts/Layout.astro';
import { persona, now } from '../data/cv';
---

<Layout
	title={`Now | ${persona.displayName}`}
	description={`What ${persona.displayName} is focused on lately (${now.updatedLabel}).`}
	ogImage="/images/voidbear-w512.png"
>
	<article class="now">
		<p class="eyebrow">/now</p>
		<h1>What I’m doing now</h1>
		<p class="updated">Last updated: <strong>{now.updatedLabel}</strong></p>
		<p class="lede">
			A lightweight snapshot inspired by the <a href="https://nownownow.com/about">/now page movement</a>: less
			than a blog, more than a bio.
		</p>
		<ul class="bullets">
			{now.bullets.map((html) => <li set:html={html}></li>)}
		</ul>
		<p class="back">
			<a href="/">← CV</a>
			<span class="sep" aria-hidden="true">·</span>
			<a href="/blog">Blog</a>
		</p>
	</article>
</Layout>

<style>
	.now {
		max-width: 62ch;
		padding-top: 6px;
	}

	.eyebrow {
		margin: 0 0 8px;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.95rem;
	}

	h1 {
		margin: 0 0 10px;
		font-size: clamp(1.7rem, 3vw, 2.2rem);
		letter-spacing: -0.03em;
	}

	.updated {
		margin: 0 0 18px;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.lede {
		margin: 0 0 18px;
		color: var(--muted);
		line-height: 1.7;
	}

	.bullets {
		margin: 0;
		padding-left: 1.2rem;
		color: var(--text);
	}

	.bullets li {
		margin: 10px 0;
	}

	.back {
		margin: 28px 0 0;
		color: var(--muted);
	}

	.sep {
		opacity: 0.55;
		padding: 0 0.5rem;
	}
</style>
