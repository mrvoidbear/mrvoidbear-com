---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Page not found | Void Bear"
	description="That page does not exist."
	robots="noindex, nofollow"
	ogImage="/images/voidbear-w512.png"
>
	<section class="lost">
		<h1>404</h1>
		<p class="lead">This URL does not point anywhere useful. Maybe it moved, or maybe the void ate it.</p>
		<p>
			<a class="home" href="/">Back to home</a>
			<span class="sep" aria-hidden="true">·</span>
			<a href="/blog">Blog</a>
		</p>
	</section>
</Layout>

<style>
	.lost {
		padding: 24px 0 48px;
		max-width: 52ch;
	}

	h1 {
		margin: 0 0 12px;
		font-size: clamp(2rem, 4vw, 2.6rem);
		letter-spacing: -0.03em;
	}

	.lead {
		margin: 0 0 20px;
		color: var(--muted);
		line-height: 1.7;
	}

	.home {
		font-weight: 700;
	}

	.sep {
		opacity: 0.55;
		padding: 0 0.5rem;
	}
</style>
