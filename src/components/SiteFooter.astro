---
const year = new Date().getFullYear();
---

<footer class="foot">
	<div class="inner">
		<p class="muted">
			© {year} Void Bear. Built with <a href="https://astro.build/">Astro</a> + <a href="https://bun.sh/">Bun</a>.
			<span class="sep" aria-hidden="true">·</span>
			<a href="/rss.xml">RSS</a>
			<span class="sep" aria-hidden="true">·</span>
			<a href="/sitemap-index.xml">Sitemap</a>
		</p>
		<p class="muted small">Employer names are intentionally omitted.</p>
	</div>
</footer>

<style>
	.foot {
		margin-top: 56px;
		border-top: 1px solid var(--border);
		padding: 28px 18px 40px;
	}

	.inner {
		max-width: var(--max);
		margin: 0 auto;
	}

	.muted {
		color: var(--muted);
		margin: 0 0 8px;
	}

	.small {
		font-size: 0.92rem;
	}

	.sep {
		opacity: 0.55;
		padding: 0 0.4rem;
	}
</style>
